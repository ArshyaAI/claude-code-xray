# Claude Code X-Ray — Transformation Demo
# Records the "58 → 83 in 4 minutes" viral GIF
#
# Usage: vhs demo.tape

Output demo.gif
Set Shell zsh
Set FontFamily "JetBrains Mono"
Set FontSize 16
Set Width 900
Set Height 600
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set PlaybackSpeed 1

# ─── Act 1: The scan ────────────────────────────────────

Sleep 500ms
Type "npx claude-code-xray"
Sleep 300ms
Enter
Sleep 5s

# ─── Act 2: The fix ─────────────────────────────────────

Sleep 1s
Type "npx claude-code-xray fix --apply"
Sleep 300ms
Enter
Sleep 8s

# ─── Act 3: Hold on the result ──────────────────────────

Sleep 3s
