      "properties": {
        "allow": { "type": "array" },
        "deny": { "type": "array" },
        "defaultMode": {
          "type": "string",
          "enum": ["default", "bypassPermissions", "plan", "acceptEdits"]
        }
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "PreToolUse": { "type": "array" },
        "PostToolUse": { "type": "array" }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
