{
  "name": "claude-code-xray",
  "version": "0.1.1",
  "description": "See inside your Claude Code setup. Fix what's broken. Share what works.",
  "type": "commonjs",
  "bin": {
    "claude-code-xray": "dist/scan/cli.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "node --test dist/**/*.test.js 2>/dev/null || echo 'no test files found'",
    "xray": "node dist/scan/cli.js",
    "xray:fix": "node dist/scan/cli.js fix",
    "xray:badge": "node dist/scan/cli.js badge"
  },
  "keywords": [
    "claude-code",
    "security",
    "audit",
    "setup",
    "configuration",
    "ai-agent",
    "developer-tools",
    "xray"
  ],
  "author": "ArshyaAI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArshyaAI/claude-code-xray"
  },
  "files": [
    "dist/scan/**/*.js",
    "dist/fix/**/*.js",
    "dist/viral/**/*.js",
    "dist/orchestrator/detect-archetype.js",
    "dist/orchestrator/history.js",
    "dist/orchestrator/adopt.js",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
